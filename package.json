{
  "name": "words",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "benchmark:scnet": "tsx scripts/benchmark-scnet.ts",
    "audit:word-quality": "tsx --env-file=.env.local scripts/audit-word-quality.ts",
    "enrich:words": "tsx --env-file=.env.local scripts/enrich-words.ts",
    "find:base-rerun-candidates": "tsx --env-file=.env.local scripts/find-base-rerun-candidates.ts",
    "prepare:base-rerun-batches": "tsx --env-file=.env.local scripts/prepare-base-rerun-batches.ts",
    "repair:hard-errors": "tsx --env-file=.env.local scripts/repair-hard-errors.ts",
    "repair:word-collisions": "tsx --env-file=.env.local scripts/repair-word-collisions.ts",
    "import:enriched": "tsx --env-file=.env.local scripts/import-enriched-words.ts",
    "cleanup:official-variants": "tsx --env-file=.env.local scripts/cleanup-official-word-variants.ts",
    "import:words": "tsx --env-file=.env.local scripts/import-words.ts",
    "import:cet4": "tsx --env-file=.env.local scripts/import-words.ts",
    "import:cet6": "tsx --env-file=.env.local scripts/import-cet6.ts",
    "import:official": "npm run import:cet4 && npm run import:cet6",
    "rebuild:official-libraries": "tsx --env-file=.env.local scripts/rebuild-official-libraries.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
